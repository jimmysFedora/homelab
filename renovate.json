{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dashboard",
  "assignees": [
    "sly"
  ],
  "labels": [
    "renovate"
  ],
  "configMigration": true,
  "prHourlyLimit": 0,
  "packageRules": [
    {
      "groupName": "kaneo",
      "matchPackageNames": [
        "ghcr.io/usekaneo/web",
        "ghcr.io/usekaneo/api"
      ]
    },
    {
      "groupName": "beszel",
      "matchPackageNames": [
        "henrygd/beszel",
        "henrygd/beszel-agent"
      ]
    },
    {
      "groupName": "pangolin",
      "matchPackageNames": [
        "ghcr.io/fosrl/pangolin",
        "ghcr.io/fosrl/gerbil",
        "ghcr.io/fosrl/newt"
      ]
    },
    {
      "groupName": "authentik",
      "matchManagers": ["kubernetes", "helm-releases", "helm-values", "flux"],
      "matchPackageNames": [
        "ghcr.io/goauthentik/server",
        "authentik"
      ]
    },
    {
      "matchPackageNames": [
        "ghcr.io/immich-app/postgres"
      ],
      "enabled": false
    },
    {
      "groupName": "cert-manager",
      "groupSlug": "cert-manager",
      "matchPackageNames": [
        "quay.io/jetstack/cert-manager-{/,}**"
      ]
    },
    {
      "matchPackageNames": [
        "docker.io/library/postgres"
      ],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "getmeili/meilisearch"
      ],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "postgres"
      ],
      "enabled": false
    }
  ],
  "docker-compose": {
    "hostRules": [
      {
        "matchHost": "docker.io",
        "concurrentRequestLimit": 2
      }
    ]
  },
  "flux": {
    "managerFilePatterns": [
      "/\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/apps/.+\\.yaml$/",
      "/infrastructure/.+\\.yaml$/"
    ]
  }
}
