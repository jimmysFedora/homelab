{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dashboard",
  "assignees": [
    "sly"
  ],
  "labels": [
    "renovate"
  ],
  "configMigration": true,
  "prHourlyLimit": 0,
  "packageRules": [
    {
      "matchManagers": ["kubernetes"],
      "matchFileNames": ["**/development/**"],
      "groupName": "kubernetes-development-{{packageName}}"
    },
    {
      "matchManagers": ["kubernetes"],
      "matchFileNames": ["**/staging/**"],
      "groupName": "kubernetes-staging-{{packageName}}"
    },
    {
      "matchManagers": ["kubernetes"],
      "matchFileNames": ["**/production/**"],
      "groupName": "kubernetes-production-{{packageName}}"
    },
    {
      "matchManagers": ["docker-compose"],
      "groupName": "docker-compose-{{packageName}}"
    }
  ],
  "docker-compose": {
    "hostRules": [
      {
        "matchHost": "docker.io",
        "concurrentRequestLimit": 2
      }
    ],
    "packageRules": [
      {
        "matchPackageNames": [
          "getmeili/meilisearch"
        ],
        "enabled": false
      },
      {
        "matchPackageNames": [
          "postgres"
        ],
        "enabled": false
      },
      {
        "matchPackageNames": [
          "ghcr.io/immich-app/postgres"
        ],
        "enabled": false
      },
      {
        "groupName": "cert-manager",
        "groupSlug": "cert-manager",
        "matchPackageNames": [
          "quay.io/jetstack/cert-manager-{/,}**"
        ]
      },
      {
        "matchPackageNames": [
          "docker.io/library/postgres"
        ],
        "enabled": false
      }
    ]
  },
  "flux": {
    "managerFilePatterns": [
      "/\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/kubernetes/.+\\.yaml$/"
    ]
  }
}